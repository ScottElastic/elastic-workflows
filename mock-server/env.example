# Copy to .env and fill in values for local development.
# In production (App Runner), set these as environment variables in the console.

BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-8
BEDROCK_REGION=us-west-2

# S3 bucket for response cache. Leave blank to use local CACHE_DIR.
S3_CACHE_BUCKET=elastic-mock-server-cache
S3_CACHE_PREFIX=cache/

# Shared API key. Required in X-Api-Key header on every request.
# Leave blank to disable auth (local dev only).
API_KEY=replace-with-a-long-random-string

PORT=8080

# Local-only: path for file-based cache (used when S3_CACHE_BUCKET is not set)
# CACHE_DIR=./cache
